{
	"name": "google-maps-link-parser",
	"version": "0.1.1",
	"description": "Bun-first TypeScript library for parsing, normalizing, unfurling, and optionally enriching public Google Maps URLs.",
	"keywords": [
		"bun",
		"coordinates",
		"geocoding",
		"google-maps",
		"maps",
		"maps-url",
		"shortlink",
		"typescript",
		"url-parser",
		"url-unfurl"
	],
	"homepage": "https://github.com/kdcokenny/google-maps-link-parser#readme",
	"bugs": {
		"url": "https://github.com/kdcokenny/google-maps-link-parser/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kdcokenny/google-maps-link-parser.git"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"default": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "bunup",
		"dev": "bunup --watch",
		"check": "bun run check:format && bun run check:lint && bun run check:types && bun run test",
		"check:format": "oxfmt --check .",
		"check:lint": "oxlint src",
		"check:types": "tsc -p tsconfig.json",
		"test": "bun test",
		"test:coverage": "bun test --coverage",
		"test:live": "LIVE_NETWORK_TESTS=1 bun test src/__tests__/live-network.test.ts",
		"test:live:providers": "LIVE_GOOGLE_API_TESTS=1 bun test src/__tests__/live-providers.test.ts",
		"docs:dev": "cd docs && mint dev",
		"docs:build": "cd docs && mint validate && mint broken-links && mint a11y --skip-contrast",
		"docs:generate-api": "typedoc --options typedoc.json",
		"prepare": "husky",
		"prepublishOnly": "bun run check && bun run docs:generate-api && bun run build"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@types/bun": "^1.2.21",
		"bunup": "^0.16.31",
		"git-cliff": "^2.10.0",
		"husky": "^9.1.7",
		"mint": "^4.2.108",
		"oxfmt": "^0.36.0",
		"oxlint": "^1.51.0",
		"pkg-pr-new": "^0.0.54",
		"typedoc": "^0.28.12",
		"typescript": "^5.9.3"
	},
	"engines": {
		"bun": ">=1.3.6",
		"node": ">=20.17.0"
	},
	"packageManager": "bun@1.3.6"
}
